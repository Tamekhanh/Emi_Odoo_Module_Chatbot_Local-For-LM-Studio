<odoo>
    <record id="view_emi_chat_form" model="ir.ui.view">
        <field name="name">emi.chat.form</field>
        <field name="model">emi.chat</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_ask_emi" 
                            string="Gửi cho Emi" 
                            type="object" 
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="message" placeholder="Hãy hỏi Emi điều gì đó..."/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Câu trả lời của Emi">
                            <field name="response" placeholder="Emi sẽ trả lời tại đây..." />
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_emi_chat" model="ir.actions.act_window">
        <field name="name">Chat với Emi</field>
        <field name="res_model">emi.chat</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_emi_chat" name="Chat" parent="menu_emi_root" action="action_emi_chat" sequence="20"/>
</odoo>